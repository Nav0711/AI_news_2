# ============================================
# MyET Frontend Environment Configuration
# ============================================
#
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
#
# Note: VITE_ prefix is required for Vite to expose variables
#

# ============================================
# API Configuration (REQUIRED)
# ============================================

# Backend API Base URL
# Change this to match your backend server location
# Development: http://localhost:8000/api
# Production: https://api.myeт.com/api
VITE_API_BASE_URL=http://localhost:8000/api

# ============================================
# Application Configuration
# ============================================

# Application name (displayed in UI)
VITE_APP_NAME=MyET

# Application environment
# Options: development, staging, production
VITE_ENVIRONMENT=development

# ============================================
# Feature Flags
# ============================================

# Enable analytics
VITE_ANALYTICS_ENABLED=false

# Enable error reporting
VITE_ERROR_REPORTING_ENABLED=false

# Enable feature tour for new users
VITE_FEATURE_TOUR_ENABLED=true

# ============================================
# UI Configuration
# ============================================

# Default theme color
# Options: light, dark, system
VITE_THEME=dark

# Enable animations
VITE_ANIMATIONS_ENABLED=true

# Enable experimental features
VITE_EXPERIMENTAL_FEATURES=false

# ============================================
# Development Configuration
# ============================================

# Enable debug logging in console
VITE_DEBUG=false

# Enable detailed API logging
VITE_DEBUG_API=false

# Enable React Developer Tools
VITE_ENABLE_DEVTOOLS=true

# ============================================
# API Configuration (Advanced)
# ============================================

# API request timeout in milliseconds
VITE_API_TIMEOUT=30000

# API retry attempts
VITE_API_RETRY_ATTEMPTS=3

# Enable request/response logging
VITE_API_LOGGING=false

# ============================================
# Authentication Configuration
# ============================================

# JWT token storage key (localStorage)
VITE_TOKEN_STORAGE_KEY=myET_auth_token

# Session timeout in minutes
VITE_SESSION_TIMEOUT=60

# Enable automatic token refresh
VITE_AUTO_TOKEN_REFRESH=true

# ============================================
# Content Configuration
# ============================================

# Articles per page in feed
VITE_ARTICLES_PER_PAGE=20

# Languages support
# Comma-separated language codes: hi, ta, te, bn, mr, gu
VITE_SUPPORTED_LANGUAGES=en,hi,ta,te,bn,mr,gu

# Enable video player
VITE_ENABLE_VIDEO_PLAYER=true

# Enable story arc timeline
VITE_ENABLE_STORY_ARC=true

# ============================================
# Analytics & Tracking
# ============================================

# Google Analytics ID (optional)
# VITE_GA_ID=UA-XXXXXXXXX-X

# Sentry DSN for error tracking (optional)
# VITE_SENTRY_DSN=https://your@sentry.io/project

# Posthog API key (optional, for feature analytics)
# VITE_POSTHOG_API_KEY=your-posthog-key

# ============================================
# Third Party Services
# ============================================

# Crisp Chat support widget (optional)
# VITE_CRISP_WEBSITE_ID=your-crisp-id

# Intercom support widget (optional)
# VITE_INTERCOM_APP_ID=your-intercom-id

# ============================================
# CDN & Assets (Optional)
# ============================================

# CDN URL for static assets
# VITE_CDN_URL=https://cdn.example.com

# Public assets path
VITE_PUBLIC_PATH=/

# ============================================
# Performance Configuration
# ============================================

# Enable service worker for offline support
VITE_ENABLE_SW=false

# Cache strategy lifetime in hours
VITE_CACHE_LIFETIME=24

# Preload critical resources
VITE_PRELOAD_CRITICAL=true

# ============================================
# Build Configuration
# ============================================

# Source map generation (development/production)
VITE_SOURCE_MAPS=true

# Minify output (production only)
VITE_MINIFY=true

# ============================================
# Development Server (Vite)
# ============================================

# Development server port (can override with npm run dev -- --port 3000)
# VITE_PORT=5173

# Automatically open browser on start
# VITE_AUTO_OPEN=true

# ============================================
# Testing Configuration
# ============================================

# Test environment flag
VITE_TEST_ENV=false

# Mock API responses for testing
VITE_MOCK_API=false

# Test API endpoint
# VITE_TEST_API_URL=http://localhost:8000/api
