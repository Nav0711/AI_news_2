# ============================================
# MyET Backend Environment Configuration
# ============================================
# 
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
#

# ============================================
# API Keys (REQUIRED)
# ============================================

# News API Key
# Get from: https://newsapi.org/register
# This is used to fetch latest news articles
NEWS_API_KEY=your_newsapi_key_here

# Google Gemini API Key
# Get from: https://ai.google.dev/tutorials/setup
# IMPORTANT: Must have billing enabled for this project
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Database Configuration (REQUIRED)
# ============================================

# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=myET
# Create free cluster at: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=myET

# MongoDB Database Name
# The database will be created automatically if it doesn't exist
MONGO_DB_NAME=myET_db

# ============================================
# Server Configuration (OPTIONAL)
# ============================================

# Backend server port (default: 8000)
BACKEND_PORT=8000

# Host to bind to (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
BACKEND_HOST=127.0.0.1

# ============================================
# Feature Flags (OPTIONAL)
# ============================================

# Enable debug mode (set to true for development)
DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable CORS for frontend origin
FRONTEND_ORIGIN=http://localhost:5173

# ============================================
# Optional Advanced Configuration
# ============================================

# JWT Secret Key (auto-generated if not provided)
# Used for authentication token signing
# JWT_SECRET_KEY=your-super-secret-key-here-min-32-chars

# Maximum articles to fetch per cycle (1000+ recommended)
MAX_ARTICLES_PER_FETCH=1000

# Enable video generation (requires additional dependencies)
VIDEO_GENERATION_ENABLED=false

# Cache expiration time in seconds (default: 3600)
CACHE_EXPIRATION=3600

# ============================================
# Gemini Model Configuration
# ============================================

# Gemini model name (default: gemini-2.5-flash)
# Options: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash

# Temperature for Gemini responses (0.0 - 2.0)
# Lower = more deterministic, Higher = more creative
GEMINI_TEMPERATURE=0.7

# Maximum tokens for Gemini responses
GEMINI_MAX_TOKENS=512

# ============================================
# Database Advanced Options
# ============================================

# Connection pool size (default: 10)
# MONGO_POOL_SIZE=10

# Connection timeout in seconds (default: 5)
# MONGO_TIMEOUT=5

# ============================================
# Email Configuration (For future use)
# ============================================

# Email service configuration (coming soon)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ============================================
# Analytics (Optional)
# ============================================

# Enable analytics collection
ANALYTICS_ENABLED=false

# Sentry DSN for error tracking
# SENTRY_DSN=https://your@sentry.io/project

# ============================================
# Testing (Development Only)
# ============================================

# Use test database for testing
# TESTING=false

# Test database name
# TEST_DB_NAME=myET_test_db
